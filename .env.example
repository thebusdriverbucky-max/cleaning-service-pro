# ============================================
# TAXI PROJECT — Environment Variables
# ============================================

# 🔑 License
LICENSE_KEY=
LICENSE_SERVER_URL=https://license-server-phi-eight.vercel.app
LICENSE_SERVER_SECRET=
LICENSE_PRODUCT=neo-taxi

# 🗄️ Database (Neon PostgreSQL recommended)
DATABASE_URL=

# 🔐 Auth
NEXTAUTH_SECRET=                        # openssl rand -base64 32
NEXTAUTH_URL=https://yourdomain.com

# 🔐 OAuth Providers (optional)
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 💳 Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# 🗺️ Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# 📧 Email (Resend — free 3000/mo at resend.com)
RESEND_API_KEY=re_...
EMAIL_FROM=bookings@yourdomain.com      # Must be verified domain in Resend

# ☁️ Cloudinary (for logo/image uploads in admin)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 🚦 Redis / Rate Limiting (Upstash recommended)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 🌐 App URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# 📬 Admin Email (fallback if not set in DB settings)
ADMIN_EMAIL=admin@yourdomain.com
