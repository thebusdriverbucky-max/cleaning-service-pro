generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────

enum UserRole {
  CUSTOMER
  CLEANER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  STRIPE
  CASH
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum ServiceFrequency {
  ONE_TIME
  WEEKLY
  BIWEEKLY
  MONTHLY
}

// ─── USER ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  passwordHash  String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  orders        CleaningOrder[]
  addresses     Address[]
  reviews       Review[]
  sessions      Session[]

  // For cleaners
  cleanerProfile CleanerProfile?
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── ADDRESS ─────────────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String? // e.g. "Home", "Office"
  street     String
  city       String
  state      String?
  postalCode String?
  country    String  @default("US")
  isDefault  Boolean @default(false)
  createdAt  DateTime @default(now())

  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders     CleaningOrder[]
}

// ─── SERVICE TYPE (CMS managed) ──────────────────────────

model ServiceType {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  description  String?
  icon         String?  // icon name or emoji
  basePrice    Float    // base price per m²  or flat rate
  pricePerSqm  Float?   // if pricing by area
  minArea      Float?
  maxArea      Float?
  durationHours Float   @default(2) // estimated duration
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders       CleaningOrder[]
}

// ─── CLEANER PROFILE ─────────────────────────────────────

model CleanerProfile {
  id          String  @id @default(cuid())
  userId      String  @unique
  bio         String?
  rating      Float   @default(0)
  totalJobs   Int     @default(0)
  isAvailable Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      CleaningOrder[]
}

// ─── CLEANING ORDER ──────────────────────────────────────

model CleaningOrder {
  id              String          @id @default(cuid())
  orderNumber     String          @unique @default(cuid())
  
  userId          String
  serviceTypeId   String
  addressId       String?
  cleanerId       String?

  // Service details
  areaSize        Float?          // in m²
  roomCount       Int?
  specialRequests String?
  accessNotes     String?         // how to get in

  // Scheduling
  scheduledDate   DateTime
  scheduledTime   String          // e.g. "10:00"
  frequency       ServiceFrequency @default(ONE_TIME)

  // Address (denormalized for history)
  addressStreet   String
  addressCity     String
  addressPostal   String?

  // Pricing
  basePrice       Float
  discount        Float           @default(0)
  totalPrice      Float

  // Payment
  paymentMethod   PaymentMethod   @default(STRIPE)
  paymentStatus   PaymentStatus   @default(UNPAID)
  stripeSessionId String?
  stripePaymentId String?
  paidAt          DateTime?

  // Status
  status          OrderStatus     @default(PENDING)
  confirmedAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  cancellationReason String?

  // Metadata
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  user            User            @relation(fields: [userId], references: [id])
  serviceType     ServiceType     @relation(fields: [serviceTypeId], references: [id])
  address         Address?        @relation(fields: [addressId], references: [id])
  cleaner         CleanerProfile? @relation(fields: [cleanerId], references: [id])
  review          Review?
}

// ─── REVIEW ──────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  orderId   String   @unique
  userId    String
  rating    Int      // 1-5
  comment   String?
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())

  order     CleaningOrder @relation(fields: [orderId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
}

// ─── CMS: SITE SETTINGS ──────────────────────────────────

model SiteSettings {
  id            String  @id @default(cuid())
  key           String  @unique
  value         String
  description   String?
  updatedAt     DateTime @updatedAt
}

// ─── CMS: PROMO CODES ────────────────────────────────────

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  discountType  String   // "percent" | "fixed"
  discountValue Float
  maxUses       Int?
  usedCount     Int      @default(0)
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
}

// ─── LICENSE (защита шаблона) ────────────────────────────

model License {
  id          String   @id @default(cuid())
  licenseKey  String   @unique
  domain      String?
  activatedAt DateTime?
  expiresAt   DateTime?
  isActive    Boolean  @default(false)
  purchaseId  String?  // ID from OwnYourWebsite payment
  createdAt   DateTime @default(now())
}
